[k3s_servers]
node1 ansible_host=192.168.1.10 ansible_user=ubuntu
node2 ansible_host=192.168.1.11 ansible_user=ubuntu

[k3s_agents]
worker1 ansible_host=192.168.1.20 ansible_user=ubuntu
worker2 ansible_host=192.168.1.21 ansible_user=ubuntu

[k3s_nodes:children]
k3s_servers
k3s_agents

[k3s_nodes:vars]
ansible_ssh_private_key_file=~/.ssh/id_ed25519
ansible_become=true
ansible_become_method=sudo
